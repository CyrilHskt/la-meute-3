# Copie ce fichier en .env.local (jamais committé, cf. .gitignore) pour
# pointer le front vers un nœud Hardhat local au lieu de Sepolia — utile
# pour tester tout le cycle (candidature -> vote -> exécution) en quelques
# secondes plutôt qu'en jours réels, via networkHelpers.time.increase.

VITE_CHAIN=local

# Adresse affichée par `npx hardhat ignition deploy ... --network localhost`
# (elle change à chaque redémarrage du nœud local, contrairement à Sepolia).
VITE_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
